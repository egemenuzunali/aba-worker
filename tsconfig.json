{
	"compilerOptions": {
		"module": "commonjs",
		"esModuleInterop": true,
		"target": "ESNext",
		"moduleResolution": "node",
		"sourceMap": true,
		"experimentalDecorators": true,
		"outDir": "dist",
		"strict": true,
		"noEmitOnError": true,
		"resolveJsonModule": true,
		"noImplicitAny": true
	},
	"lib": ["es2015"],
	"include": ["src/**/*.ts"],
	"exclude": ["node_modules"]
}
