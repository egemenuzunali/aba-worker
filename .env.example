# ABA Worker Environment Variables

# ===================================
# Core Configuration
# ===================================

# Port for HTTP server (health checks and metrics)
PORT=4008

# Application environment (development | test | production)
NODE_ENV=development

# Logging level (error | warn | info | debug)
LOG_LEVEL=info

# MongoDB connection string (REQUIRED)
MONGO_STRING=mongodb+srv://user:password@cluster.mongodb.net/database?tls=true&authSource=admin

# ===================================
# RDW API Configuration
# ===================================

# RDW API key for vehicle data synchronization (optional - uses mock data if not provided)
RDW_API_KEY=your-rdw-api-key-here

# RDW API base URL
RDW_BASE_URL=https://api.rdw.nl

# ===================================
# Service Enable/Disable Flags
# All default to TRUE if not specified
# Set to "false" to disable a service
# ===================================

# Document expiry checking (daily at 12:00 AM)
# Master flag - if false, all document checks are disabled
ENABLE_DOCUMENT_EXPIRY_CHECK=true

# Granular document expiry flags (only apply if ENABLE_DOCUMENT_EXPIRY_CHECK=true)
# Control each document type independently
ENABLE_QUOTE_EXPIRY_CHECK=true
ENABLE_INVOICE_EXPIRY_CHECK=true
ENABLE_PURCHASE_INVOICE_EXPIRY_CHECK=true

# Full RDW sync (every Sunday at 2:00 AM, only if 6+ weeks since last sync)
# Syncs ALL vehicles with RDW API for comprehensive data refresh
ENABLE_RDW_FULL_SYNC=true

# Daily RDW sync (daily at 1:00 AM)
# Syncs ONLY vehicles with expired or expiring APK for targeted updates
ENABLE_RDW_DAILY_SYNC=true

# APK status check (weekly on Sunday at 1:30 AM)
# Checks APK expiry status and creates notifications
ENABLE_APK_STATUS_CHECK=true

# Maintenance reminders (weekly on Sunday at 3:00 AM)
# Checks for due and overdue maintenance, creates notifications
ENABLE_MAINTENANCE_REMINDERS=true

# ===================================
# Testing/Development Variables
# Run tests at startup for specific services
# (Optional - only used for testing)
# ===================================

# Company ID to use for test syncs
TEST_SYNC_COMPANY_ID=

# Test document expiry checking on startup (quotes, invoices, purchase invoices)
TEST_SYNC_STATUS_UPDATE=false

# Test APK status check on startup (creates notifications, NO RDW sync)
TEST_SYNC_APK_STATUS=false

# Test RDW sync on startup (fetches data from RDW API)
TEST_SYNC_RDW=false

# Test maintenance reminders on startup
TEST_SYNC_MAINTENANCE=false

# API URL (for future use)
API_URL=http://localhost:4000

# Debug mode (for development)
DEBUG=false
